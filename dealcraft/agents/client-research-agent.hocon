{
    "agent_definitions": {

        "client-research-agent": {

            "name": "client-research-agent",
            "description": "Specialist agent that researches a given client company and produces a structured Client Intelligence Brief covering company overview, strategic priorities, pain points, recent news, technology landscape, and Cognizant relationship.",

            # Path to the system prompt for this agent
            "instructions": "prompts/client-research-prompt.md",

            # LLM configuration — inherits from global llm_config.hocon
            "llm_config": ${llm_config},

            # This is a leaf agent — no downstream tools
            "tools": []
        }
    }
}